---
import BentoHero from './BentoHero.astro'
import BentoAbout from './BentoAbout.astro'
import BentoTimeline from './BentoTimeline.astro'
import BentoSocials from './BentoSocials.astro'
import BentoProjectCards from './BentoProjectCards.astro'
import SkillBubbles from '../ui/SkillBubbles'
import { t, getLocalizedUrl, getContactUrl, profileBase } from '../../i18n'
import type { Locale } from '../../i18n/utils'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const biteRadius = '100px'
---

<div class="shared-layout-container overflow-hidden">

  {/* MOBILE STICKY HEADER - Solo visible en móvil/tablet */}
  <div class="mobile-sticky-header lg:hidden">
    <div class="mobile-header-avatar">
      <img src="/me.jpg" alt="Profile" class="w-full h-full object-cover" loading="eager" />
    </div>
    <div class="mobile-header-nav">
      {/* Navigation links for mobile */}
      <a href={getLocalizedUrl(locale, '/projects')} class="text-[10px] font-bold tracking-widest text-gray-400 uppercase hover:text-white transition-colors">{t(locale, 'nav.projects')}</a>
      <a href={getContactUrl(locale)} class="text-[10px] font-bold tracking-widest text-purple-400 uppercase hover:text-purple-300 transition-colors">{t(locale, 'nav.contact')}</a>
    </div>
    <div class="flex gap-2">
      <BentoSocials compact locale={locale} />
    </div>
  </div>

  <style is:global>
    @media (max-width: 1023px) {
      .mobile-mask-reset {
        -webkit-mask-image: none !important;
        mask-image: none !important;
      }
    }
  </style>

  {/* Main Container - Aspect Video on Desktop, Auto on Mobile */}
  <div class="shared-layout-inner lg:aspect-video flex flex-col lg:block relative">

    {/* Grid Container */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 lg:grid-rows-4 gap-4 w-full h-full">

      {/* --- COLUMN 1 --- */}

      {/* Top Left: Skills */}
      <div class="lg:col-start-1 lg:row-start-1 lg:row-span-2 bg-[#13131f] rounded-3xl p-4 flex flex-col border border-white/5 relative overflow-hidden group h-64 md:h-72 lg:h-auto">
        <SkillBubbles client:visible title={t(locale, 'skills.title')} />
      </div>

      {/* Bottom Left: About */}
      <div class="lg:col-start-1 lg:row-start-3 lg:row-span-2 bg-[#13131f] rounded-3xl p-4 flex flex-col border border-white/5 relative overflow-hidden h-64 md:h-auto lg:h-auto">
        <BentoAbout locale={locale} />
      </div>

      {/* --- CENTER COLUMN (2 & 3) --- */}

      {/* Top Center: Hero */}
      <div
        class="md:col-span-2 lg:col-start-2 lg:col-span-2 lg:row-start-1 lg:row-span-2 bg-[#5b21b6] rounded-3xl p-4 flex flex-col items-center text-center relative overflow-hidden border border-white/10 h-72 md:h-80 lg:h-auto mobile-mask-reset"
        style={`mask-image: radial-gradient(circle at 50% calc(100% + 8px), transparent ${biteRadius}, black ${biteRadius}); -webkit-mask-image: radial-gradient(circle at 50% calc(100% + 8px), transparent ${biteRadius}, black ${biteRadius});`}
      >
        <div class="absolute inset-0 bg-gradient-to-b from-[#7c3aed] to-[#4c1d95] opacity-100"></div>
        <BentoHero locale={locale} />
      </div>

      {/* Bottom Center: Timeline */}
      <div
        class="md:col-span-2 lg:col-start-2 lg:col-span-2 lg:row-start-3 lg:row-span-2 bg-[#13131f] rounded-3xl p-4 flex flex-col border border-white/5 relative group overflow-hidden h-80 md:h-auto lg:h-auto mobile-mask-reset"
        style={`mask-image: radial-gradient(circle at 50% -8px, transparent ${biteRadius}, black ${biteRadius}); -webkit-mask-image: radial-gradient(circle at 50% -8px, transparent ${biteRadius}, black ${biteRadius});`}
      >
        <BentoTimeline locale={locale} />
      </div>

      {/* --- COLUMN 4 --- */}

      {/* Top Right: Socials - Oculto en móvil, compact height */}
      <div class="hidden lg:flex lg:col-start-4 lg:row-start-1 bg-[#13131f] rounded-3xl p-3 items-center justify-center border border-white/5">
        <BentoSocials locale={locale} />
      </div>

      {/* Right Column: Projects */}
      <div class="md:col-span-2 lg:col-span-1 lg:col-start-4 lg:row-start-2 lg:row-span-3 bg-[#13131f] rounded-3xl p-4 flex flex-col border border-white/5 relative overflow-hidden h-96 md:h-auto lg:h-auto">
        <BentoProjectCards locale={locale} />
      </div>
    </div>

    {/* CENTRAL ORB - User Photo */}
    {/* Mobile: Oculto (foto en header sticky). Desktop: Centrado absolutamente */}
    <div class="
      hidden lg:flex
      lg:absolute lg:top-1/2 lg:left-1/2 lg:-translate-x-1/2 lg:-translate-y-1/2 lg:w-[200px] lg:h-[200px]
      pointer-events-none items-center justify-center z-20
    ">
      {/* Outer Ring */}
      <div class="absolute inset-0 rounded-full border border-white/10 shadow-[0_0_30px_rgba(124,58,237,0.2)]"></div>
      {/* Inner Spinning Rings */}
      <div class="absolute w-[90%] h-[90%] border border-white/5 rounded-full animate-[spin_10s_linear_infinite]"></div>
      <div class="absolute w-[80%] h-[80%] border border-white/5 rounded-full animate-[spin_15s_linear_infinite_reverse]"></div>
      {/* Core Orb with Photo */}
      <div class="w-[65%] h-[65%] rounded-full bg-black relative overflow-hidden shadow-[0_0_50px_rgba(139,92,246,0.6)] border border-white/20 pointer-events-auto">
        <div class="absolute inset-0 bg-gradient-to-tr from-orange-500 via-purple-600 to-blue-500 opacity-80 blur-md animate-pulse"></div>
        <div class="absolute inset-1 bg-black rounded-full overflow-hidden flex items-center justify-center">
          <img src="/me.jpg" alt={`Foto de ${profileBase.name}`} class="w-full h-full object-cover opacity-90 hover:opacity-100 transition-opacity duration-500" loading="eager" />
        </div>
      </div>
    </div>

  </div>
</div>
